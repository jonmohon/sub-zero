# Resend API key — create one at https://resend.com/api-keys
RESEND_API_KEY=

# Destination address for contact form submissions
FORM_TO_EMAIL=changeme@example.com

# Sender address shown on the email. Must be from a domain you've verified
# in Resend. For local testing you can use onboarding@resend.dev.
FORM_FROM_EMAIL=onboarding@resend.dev

# Google Places API (New) — pulls live Google reviews into the homepage
# GoogleReviewsSection and renders Review/AggregateRating schema.
#
# The Place ID is already committed in src/lib/constants.ts (BUSINESS.googlePlacesId).
# You only need to set the API key below.
#
# Setup (one-time, ~5 minutes):
#   1. Create a Google Cloud project + enable "Places API (New)":
#      https://console.cloud.google.com/apis/library/places.googleapis.com
#   2. Create an API key (restrict to Places API + production domain):
#      https://console.cloud.google.com/apis/credentials
#   3. Set the env var below (in Vercel project settings + .env.local for dev).
#
# If unset, the GoogleReviewsSection falls back to a "View Reviews on Google"
# CTA card. No errors, no broken UI — just no live reviews until configured.
GOOGLE_PLACES_API_KEY=

# Optional: override the Place ID per environment (testing/staging). Leave
# unset to use the default in BUSINESS.googlePlacesId.
# GOOGLE_PLACES_PLACE_ID=
